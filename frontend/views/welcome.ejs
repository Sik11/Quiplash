<section class="screen welcome-screen">
    <div class="screen-hero">
        <p class="eyebrow">Admin setup</p>
        <h2 class="screen-title">Start the room from this device</h2>
        <p class="screen-copy">Quiplash is a party game where players answer prompts, vote for the funniest responses, and build points across multiple rounds. Keep this device open as the admin screen, then share the join link so everyone else can connect from their own phones.</p>
    </div>

    <div class="info-grid">
        <article class="info-card">
            <span class="stat-label">How it works</span>
            <p class="screen-copy">Players sign in, the admin starts the round, everyone writes answers, and the room votes on the funniest picks.</p>
        </article>
        <article class="info-card">
            <span class="stat-label">What to share</span>
            <p class="screen-copy">Send this join link to the group. Anyone on the same network can open it and join the lobby.</p>
        </article>
    </div>

    <div class="share-card">
        <span class="stat-label">Join link</span>
        <p class="share-link">{{ joinUrl }}</p>
        <div class="action-row">
            <button type="button" class="primary-button" @click="copyJoinLink">Copy Join Link</button>
            <button type="button" class="secondary-button" @click="dismissWelcomeScreen">Continue to Lobby</button>
        </div>
        <p v-if="shareStatus" class="feedback success-message">{{ shareStatus }}</p>
    </div>
</section>
