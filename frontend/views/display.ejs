<!doctype html>
<html lang="en">
<%- include('partials/header'); -%>

<div id="game" class="app-shell display-shell">
    <div class="app-backdrop"></div>

    <header class="shell-nav">
        <div>
            <p class="eyebrow">Room display</p>
            <h1 class="brand">Quiplash</h1>
        </div>
        <div class="nav-actions">
            <span class="connection-pill" :class="connected ? 'online' : 'offline'">
                {{ connected ? 'Connected' : 'Connecting' }}
            </span>
            <button type="button" class="theme-toggle" @click="toggleTheme">
                {{ theme === 'dark' ? 'Light mode' : 'Dark mode' }}
            </button>
        </div>
    </header>

    <section class="panel display-panel" v-if="connected && isWatchingRoom">
        <div class="screen">
            <div class="screen-hero">
                <p class="eyebrow">Room {{ roomCode }}</p>
                <h2 class="screen-title">Live game display</h2>
                <p class="screen-copy">Showing the public game state and room feed for this session.</p>
            </div>

            <div class="stat-row">
                <div class="stat-card">
                    <span class="stat-label">Game state</span>
                    <strong>{{ stateLabel }}</strong>
                </div>
                <div class="stat-card">
                    <span class="stat-label">Round</span>
                    <strong>{{ publicState.round || 0 }}</strong>
                </div>
                <div class="stat-card">
                    <span class="stat-label">Players</span>
                    <strong>{{ playerCount }}</strong>
                </div>
                <div class="stat-card">
                    <span class="stat-label">Audience</span>
                    <strong>{{ audienceCount }}</strong>
                </div>
            </div>

            <div class="player-grid">
                <article v-for="player in players" class="player-card">
                    <span class="player-badge" v-if="player.admin">Admin</span>
                    <strong>{{ player.name }}</strong>
                    <span>{{ player.totalScore || 0 }} pts</span>
                </article>
            </div>

            <div class="share-card" v-if="publicState.currentPrompt">
                <span class="stat-label">Current prompt</span>
                <p class="share-link">{{ publicState.currentPrompt }}</p>
            </div>

            <div>
                <p class="eyebrow">Live feed</p>
                <ul id="chat" class="chat-list display-chat">
                    <li v-for="message in messages">
                        <strong>{{ message.sender }}:</strong> {{ message.text }}
                    </li>
                </ul>
            </div>
        </div>
    </section>

    <section class="panel display-panel" v-else-if="connected">
        <div class="screen auth-screen">
            <div class="screen-hero">
                <p class="eyebrow">Room display</p>
                <h2 class="screen-title">Choose a room to display</h2>
                <p class="screen-copy">Enter a room code to show the live state for that specific game.</p>
            </div>

            <form class="stack-form" @submit.prevent="selectRoom">
                <label class="field">
                    <span>Room code</span>
                    <input type="text" v-model="roomCodeInput" placeholder="Enter code" maxlength="5" required>
                </label>

                <div class="action-row">
                    <button type="submit" class="primary-button">Open Display</button>
                </div>
            </form>

            <p v-if="roomError" class="feedback error-message">{{ roomError }}</p>
        </div>
    </section>

    <section class="panel display-panel" v-else>
        <p class="eyebrow">Session status</p>
        <h2 class="screen-title">Connecting to room display</h2>
        <p class="screen-copy">Waiting for the websocket connection.</p>
    </section>
</div>

<script>
    window.QUIPLASH_DISPLAY_BOOT = <%- JSON.stringify({ initialRoomCode }) %>;
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p" crossorigin="anonymous"></script>
<script src="https://cdn.socket.io/4.3.2/socket.io.min.js" integrity="sha384-KAZ4DtjNhLChOB/hxXuKqhMLYvx3b5MlT55xPEiNmREKRzeEm+RVPlTnAn0ajQNs" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.js"></script>
<script src="/static/display.js"></script>
</body>
</html>
